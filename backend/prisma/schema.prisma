generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model About {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  // Roles will be an array of strings, e.g., ["Full Stack Developer", "Designer"]
  roles       String[]
  description String
  // We will store the image and CV as base64 strings
  image       String?
  cv          String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Link {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  linkedin  String?
  github    String?
  instagram String?
  portal    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SkillCategory {
  id     String  @id @default(auto()) @map("_id") @db.ObjectId
  name   String  @unique // Category names must be unique
  // This creates the one-to-many relationship
  skills Skill[]
}

model Skill {
  id         String        @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  image      String // This will store the path to the skill's image
  // This is the foreign key linking back to the category
  categoryId String        @db.ObjectId
  category   SkillCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model Experience {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  logo        String
  role        String
  companyName String
  companyLink String?
  startDate   DateTime
  endDate     DateTime? // A null value here will signify "Present"
  description String
  skills      String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model User {
  id              String  @id @default(auto()) @map("_id") @db.ObjectId
  email           String  @unique
  password        String
  resetToken      String? // To store the password reset token
  resetTokenExpiry DateTime? // To store the reset token's expiry time
}

model ProjectCategory {
  id       String    @id @default(auto()) @map("_id") @db.ObjectId
  name     String    @unique
  projects Project[]
}

model Project {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  projectImage String
  startDate    DateTime
  endDate      DateTime? // Null signifies "Present"
  
  githubLink String?
  liveLink   String?
  tags       String[]  @default([])

  // --- Relationships ---
  categoryId String          @db.ObjectId
  category   ProjectCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  members ProjectMember[] // A project can have many members
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Member {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  profileImage  String?         // <-- ADD THIS FIELD to store the image URL
  linkedinLink  String?
  githubLink    String?
  projects      ProjectMember[]
}

model ProjectMember {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  role      String  // e.g., "Frontend Developer", "UI/UX Designer"

  // --- Relationships ---
  projectId String  @db.ObjectId
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  memberId String @db.ObjectId
  member   Member @relation(fields: [memberId], references: [id], onDelete: Restrict)
}